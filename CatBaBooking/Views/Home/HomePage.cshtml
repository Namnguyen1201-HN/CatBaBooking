@{
Layout = null;
}
@using CatBaBooking.ViewModels.Homestay
@using CatBaBooking.ViewModels.Restaurant

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cát Bà Booking - Đặt phòng homestay và nhà hàng tại Cát Bà</title>
    <link rel="stylesheet" href="~/css/HomePage/home-style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        .detail-btn {
            text-decoration: none;
            position: absolute;
            bottom: 16px;
            right: 16px;
            background-color: #28a745;
            color: #ffffff;
            border: 1px solid #28a745;
            padding: 6px 12px;
            border-radius: 4px;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            z-index: 10;
            display: block;
        }
        .detail-btn:hover { background-color: #218838; border-color: #1e7e34; color: #ffffff; transform: translateY(-1px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .homestay-card, .restaurant-card { position: relative; display: flex; flex-direction: column; }
        .bottom-section { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding: 8px 0; }
    </style>
</head>
<body>
@await Html.PartialAsync("Sidebar")

<!-- Hero Section -->
<section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-bg"></div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1>Khám phá vẻ đẹp Cát Bà</h1>
                <p>Trải nghiệm homestay đích thực và ẩm thực địa phương</p>
            </div>

            <div class="service-tabs">
                <div class="tabs-container">
                    <button class="tab-btn active" data-tab="homestay"><i class="fas fa-home"></i><span>Homestay</span></button>
                    <button class="tab-btn" data-tab="restaurant"><i class="fas fa-utensils"></i><span>Nhà hàng</span></button>
                </div>
            </div>

            <div class="search-forms">
                <!-- Homestay Search -->
                <div class="search-form active" id="homestay-form">
                    <div class="form-tabs">
                        <button class="form-tab active"><i class="fas fa-home"></i><span>Homestay</span></button>
                        <button class="form-tab"><span>Villa</span></button>
                        <button class="form-tab"><span>Phòng đôi</span></button>
                    </div>
                    <form action="/homestay-page" method="GET">
                        <div class="form-grid" style="display:flex;flex-wrap:wrap;gap:15px;align-items:end;">
                            <div class="form-field" style="flex:0 0 200px;">
                                <label>Khu vực</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <select name="areaId" class="form-select">
                                        <option value="0">Tất cả khu vực</option>
                                        <option value="1">Cát Cò 1</option>
                                        <option value="2">Cát Cò 2</option>
                                        <option value="3">Trung tâm thị trấn</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 220px;">
                                <label>Ngày nhận</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-calendar"></i>
                                    <input type="date" name="checkIn" class="form-input">
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 220px;">
                                <label>Ngày trả</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-calendar"></i>
                                    <input type="date" name="checkOut" class="form-input">
                                </div>
                            </div>
                            <div class="form-field-group" style="flex:0 0 220px;display:flex;gap:10px;">
                                <div class="form-field" style="flex:1;">
                                    <label>Số người</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-users"></i>
                                        <input type="number" name="guests" class="form-input" min="1" value="1">
                                    </div>
                                </div>
                                <div class="form-field" style="flex:1;">
                                    <label>Số phòng</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-door-open"></i>
                                        <input type="number" name="numRooms" class="form-input" min="1" value="1">
                                    </div>
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 200px;">
                                <button type="submit" class="search-btn"><i class="fas fa-search"></i> Tìm homestay</button>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Restaurant Search -->
                <div class="search-form" id="restaurant-form">
                    <div class="form-tabs">
                        <button class="form-tab active"><i class="fas fa-utensils"></i><span>Tất cả</span></button>
                        <button class="form-tab"><span>Hải sản</span></button>
                        <button class="form-tab"><span>Món Việt</span></button>
                        <button class="form-tab"><span>BBQ</span></button>
                    </div>
                    <form action="/restaurant-page" method="GET">
                        <div class="form-grid" style="display:flex;flex-wrap:wrap;gap:15px;align-items:end;">
                            <div class="form-field" style="flex:0 0 200px;">
                                <label>Loại hình</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-utensils"></i>
                                    <select name="restaurantType" class="form-select">
                                        <option value="">Loại nhà hàng</option>
                                        <option value="1">Hải sản</option>
                                        <option value="2">Món Việt</option>
                                        <option value="3">BBQ</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 220px;">
                                <label>Khu vực tại Cát Bà</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <select name="areaId" class="form-select">
                                        <option value="0">Chọn khu vực</option>
                                        <option value="1">Cát Cò 1</option>
                                        <option value="2">Trung tâm</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 180px;">
                                <label>Ngày đặt bàn</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-calendar"></i>
                                    <input type="date" name="date" class="form-input">
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 150px;">
                                <label>Giờ</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-clock"></i>
                                    <input type="time" name="time" class="form-input">
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 100px;">
                                <label>Số người</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-users"></i>
                                    <input type="number" name="numGuests" class="form-input" min="1">
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 150px;">
                                <button type="submit" class="search-btn"><i class="fas fa-search"></i> Tìm nhà hàng</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="hero-features">
                <div class="features-container">
                    <p class="features-title">Tại sao chọn chúng tôi?</p>
                    <div class="features-list">
                        <span>🏡 Homestay chính chủ</span>
                        <span>🍜 Đặc sản địa phương</span>
                        <span>🌊 View đẹp nhất</span>
                        <span>💰 Giá tốt nhất</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Homestays -->
<section class="featured-homestays">
    <div class="container">
        <div class="section-header">
            <div>
                <h2>Homestay nổi bật</h2>
                <p>Những homestay được yêu thích nhất tại Cát Bà</p>
            </div>
            <a href="/homestay-page" class="view-all-btn"><span>Xem tất cả</span><i class="fas fa-chevron-right"></i></a>
        </div>
        <div class="homestays-grid">
            @{
                var featuredHomestays = ViewBag.FeaturedHomestays as IEnumerable<HomestayCardViewModel>;
            }

            @if (featuredHomestays != null && featuredHomestays.Any())
            {
                @foreach(var homestay in featuredHomestays)
                {
                    <div class="homestay-card">
                        <div class="card-image">
                            <img src="@(homestay.ThumbnailUrl ?? "/images/default-homestay.jpg")" alt="@(homestay.Name)">
                            <div class="badge type">
                                <i class="fas fa-home"></i> Homestay
                            </div>
                        </div>
                        <div class="card-content">
                            <div class="rating">
                                <div class="stars">
                                    @{
                                        int fullStars = (int)Math.Floor(homestay.AverageRating);
                                        bool hasHalf = (homestay.AverageRating - fullStars) >= 0.5;
                                    }
                                    @for (int i = 0; i < fullStars; i++)
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    @if (hasHalf)
                                    {
                                        <i class="fas fa-star-half-alt"></i>
                                    }
                                    @for (int i = fullStars + (hasHalf ? 1 : 0); i < 5; i++)
                                    {
                                        <i class="far fa-star"></i>
                                    }
                                </div>
                                <span class="reviews">(@homestay.ReviewCount)</span>
                            </div>
                            <h3>
                                <a href="/homestay/detail/@homestay.BusinessId" style="color:inherit;text-decoration:none;">
                                    @homestay.Name
                                </a>
                            </h3>
                            <div class="location">
                                <i class="fas fa-map-marker-alt"></i> @homestay.AreaName, Cát Bà
                            </div>
                            <a class="detail-btn" href="/homestay/detail/@homestay.BusinessId">Chi tiết</a>
                            <div class="price-section">
                                <div class="price">
                                    <span class="current-price">@homestay.PriceFrom.ToString("N0")₫</span>
                                    <div class="per-night">mỗi đêm</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

            }
            else 
            {
                <p> Chưa có homestay nổi bật. </p>
            }
        </div>
    </div>
</section>

<!-- Promo Section -->
<section class="promo-section">
    <div class="container">
        <div class="promo-grid">
            <div class="promo-card emerald">
                <div class="promo-image">
                    <img src="https://images.unsplash.com/photo-1710702418104-6bf5419ab03d?w=600&h=300&fit=crop" alt="Ưu đãi cuối tuần">
                </div>
                <div class="promo-content">
                    <h3>Ưu đãi cuối tuần</h3>
                    <p>Giảm 30% cho đặt phòng homestay cuối tuần</p>
                    <button class="promo-btn">Đặt ngay</button>
                </div>
            </div>
            <div class="promo-card orange">
                <div class="promo-image">
                    <img src="https://images.unsplash.com/photo-1619900950180-4a099c7aaeb1?w=600&h=300&fit=crop" alt="Combo ăn uống">
                </div>
                <div class="promo-content">
                    <h3>Combo ăn uống</h3>
                    <p>Đặt bàn + homestay nhận ngay voucher 100k</p>
                    <button class="promo-btn">Khám phá</button>
                </div>
            </div>
        </div>
    </div>
</section>

    <!-- Featured Restaurants -->
    <section class="featured-restaurants">
        <div class="container">
            <div class="section-header">
                <div>
                    <h2>Nhà hàng đặc sắc</h2>
                    <p>Thưởng thức hải sản tươi ngon và đặc sản địa phương</p>
                </div>
                <a href="/restaurant-page" class="view-all-btn"><span>Xem tất cả</span><i class="fas fa-chevron-right"></i></a>
            </div>
            <div class="restaurants-grid">
                @{
                    var featuredRestaurants = ViewBag.FeaturedRestaurants as IEnumerable<RestaurantCardViewModel>;
                }
                @if (featuredRestaurants != null && featuredRestaurants.Any())
                {
                    @foreach (var restaurant in featuredRestaurants)
                    {
                        <div class="restaurant-card">
                            <div class="card-image">
                                <img src="@(restaurant.ThumbnailUrl ?? "/images/default-restaurant.jpg")" alt="@restaurant.Name" />
                            </div>
                            <div class="badge cuisine">
                                <i class="fas fa-utensils"></i> Nhà hàng
                            </div>
                           
                            <div class="card-content">
                                <div class="rating">
                                    <div class="stars">
                                        
                                        @{
                                            int rFullStars = (int)Math.Floor(restaurant.AverageRating);
                                            bool rHasHalf = (restaurant.AverageRating - rFullStars) >= 0.5;
                                        }

                                        
                                        @for (int i = 0; i < rFullStars; i++)
                                        {
                                            <i class="fas fa-star"></i>
                                        }

                                        
                                        @if (rHasHalf)
                                        {
                                            <i class="fas fa-star-half-alt"></i>
                                        }

                                        
                                        @for (int i = rFullStars + (rHasHalf ? 1 : 0); i < 5; i++)
                                        {
                                            <i class="far fa-star"></i>
                                        }
                                    </div>
                                    <span class="reviews">(@restaurant.ReviewCount)</span>
                                </div>
                                <h3>
                                    <a href="/restaurant/detail/@restaurant.BusinessId"
                                       style="color:inherit;text-decoration:none;">
                                        @restaurant.Name
                                    </a>
                                </h3>
                                <div class="location">
                                    <i class="fas fa-map-marker-alt"></i> @restaurant.AreaName, Cát Bà
                                </div>
                                <div class="hours">
                                    <i class="fas fa-clock"></i>
                                    @(restaurant.OpeningTime ?? "?") - @(restaurant.ClosingTime ?? "?")
                                </div>
                                <a class="detail-btn" href="/restaurant/detail/@restaurant.BusinessId">Đặt bàn</a>
                            </div>
                        </div> 
                    }
                }
                else
                {
                    <p>Chưa có nhà hàng nổi bật.</p>
                }
            </div>
        </div>
    </section>

@await Html.PartialAsync("Footer")

<style>
    .user-dropdown { display:flex;align-items:center;gap:.5rem;background:rgba(255,255,255,.1);padding:.5rem .75rem;border-radius:9999px;cursor:pointer;transition:all .3s;color:white;position:relative;z-index:1002; }
    .user-dropdown:hover { background:rgba(255,255,255,.2); }
    .user-dropdown i.fa-chevron-down { transition:transform .3s; }
    .user-dropdown.active i.fa-chevron-down { transform:rotate(180deg); }
    .dropdown-menu { display:none;position:absolute;top:100%;right:0;background:white;border-radius:1rem;box-shadow:0 25px 50px -12px rgba(0,0,0,.25);min-width:320px;z-index:1001;overflow:hidden;transform:scaleY(0);transform-origin:top;transition:all .3s cubic-bezier(.34,1.56,.64,1); }
    .dropdown-menu.show { display:block;transform:scaleY(1); }
    .top-bar-right { position:relative; }
    .user-info { padding:1.5rem;display:flex;align-items:center;gap:1rem;background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-bottom:1px solid #e2e8f0; }
    .avatar { width:48px;height:48px;border-radius:50%;object-fit:cover;border:3px solid #e2e8f0; }
    .user-info strong { font-size:1rem;color:#1e293b;display:block;font-weight:600; }
    .dropdown-list { list-style:none;margin:0;padding:0; }
    .dropdown-list li { padding:1rem 1.5rem;display:flex;align-items:center;gap:1rem;color:#475569;font-size:.95rem;transition:all .3s;border-bottom:1px solid #f1f5f9;cursor:pointer; }
    .dropdown-list li:hover { background:linear-gradient(to right,#ecfdf5,#f0fdf4);color:#059669;transform:translateX(5px); }
    .dropdown-list li:last-child { border-bottom:none; }
    .dropdown-list a { color:inherit;text-decoration:none;width:100%; }
    .dropdown-list i { width:20px;text-align:center;opacity:.6;transition:all .2s; }
    .dropdown-list li:hover i { opacity:1;color:#059669; }
</style>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const tabBtns = document.querySelectorAll('.tab-btn');
        const searchForms = document.querySelectorAll('.search-form');
        tabBtns.forEach(btn => {
            btn.addEventListener('click', function () {
                const targetTab = this.getAttribute('data-tab');
                tabBtns.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                searchForms.forEach(form => {
                    form.classList.remove('active');
                    if (form.id === targetTab + '-form') form.classList.add('active');
                });
            });
        });
        const userDropdown = document.getElementById('userDropdown');
        const dropdownMenu = document.getElementById('dropdownMenu');
        if (userDropdown) {
            userDropdown.addEventListener('click', function (e) {
                e.stopPropagation();
                dropdownMenu.classList.toggle('show');
                userDropdown.classList.toggle('active');
            });
            document.addEventListener('click', function () {
                dropdownMenu.classList.remove('show');
                userDropdown.classList.remove('active');
            });
        }
    });
</script>
</body>
</html>
