

@model CatBaBooking.ViewModels.Homestay.CheckoutHomestayViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Xác nhận Đặt phòng - Homestay Ocean View</title>
    <link rel="stylesheet" href="~/css/HomePage/home-style.css">
    <link rel="stylesheet" href="~/css/HomePage/homestaydetail-style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <style>
        .checkout-page{padding:2rem 0;background-color:#f9fafb;min-height:80vh;}
        .checkout-layout{display:grid;grid-template-columns:2fr 1fr;gap:2rem;}
        .form-card,.summary-card{background:white;border:1px solid #e5e7eb;border-radius:.5rem;box-shadow:0 4px 6px -1px rgba(0,0,0,.05);}
        .form-card{padding:2rem;}
        .form-card h2{font-size:1.5rem;font-weight:600;color:#111827;margin-bottom:1.5rem;border-bottom:1px solid #e5e7eb;padding-bottom:1rem;}
        .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;}
        .form-group{margin-bottom:1.25rem;}
        .form-group.full-width{grid-column:1/-1;}
        .form-label{display:block;font-size:.875rem;font-weight:500;color:#374151;margin-bottom:.5rem;}
        .form-input{width:100%;padding:.75rem 1rem;font-size:.9rem;border:1px solid #d1d5db;border-radius:.375rem;box-shadow:0 1px 2px 0 rgba(0,0,0,.05);box-sizing:border-box;}
        .form-input:focus{outline:none;border-color:#059669;box-shadow:0 0 0 2px rgba(5,150,105,.3);}
        textarea.form-input{min-height:100px;resize:vertical;}
        .summary-card{position:sticky;top:1rem;}
        .summary-card h3{font-size:1.25rem;font-weight:600;color:#111827;padding:1.5rem;border-bottom:1px solid #e5e7eb;}
        .summary-card h4{font-size:1rem;font-weight:500;color:#111827;padding:0 1.5rem;margin-top:1rem;margin-bottom:.5rem;}
        .summary-item-list{padding:1rem 1.5rem;border-bottom:1px solid #e5e7eb;}
        .summary-item{display:flex;justify-content:space-between;align-items:flex-start;padding:.75rem 0;border-bottom:1px dashed #e5e7eb;}
        .summary-item:last-child{border-bottom:none;}
        .summary-item-name{font-size:.9rem;font-weight:500;color:#374151;}
        .summary-item-meta{font-size:.8rem;color:#6b7280;}
        .summary-item-price{font-size:.9rem;font-weight:500;color:#111827;white-space:nowrap;}
        .summary-details{padding:1rem 1.5rem;border-bottom:1px solid #e5e7eb;}
        .detail-row{display:flex;justify-content:space-between;font-size:.875rem;color:#374151;margin-bottom:.5rem;}
        .detail-row .label{color:#6b7280;}
        .summary-total{padding:1.5rem;background-color:#f9fafb;}
        .total-row{display:flex;justify-content:space-between;align-items:baseline;font-size:1.25rem;font-weight:600;color:#111827;}
        .confirm-btn{width:100%;display:flex;justify-content:center;align-items:center;gap:.5rem;background:#059669;color:white;border:none;border-radius:0 0 .5rem .5rem;font-size:1rem;font-weight:600;padding:1rem;cursor:pointer;}
        .confirm-btn:hover{background:#047857;}
        @@media(max-width:992px){.checkout-layout{grid-template-columns:1fr;}.summary-card{position:static;}}
        .header{background:linear-gradient(135deg,#059669,#065f46);color:white;padding:1rem 0;}
        .nav-content{display:flex;justify-content:space-between;align-items:center;}
        .logo{font-size:1.5rem;font-weight:bold;display:flex;align-items:center;text-decoration:none;}
        .logo-main{color:white;}.logo-sub{color:#a7f3d0;margin-left:.25rem;}
    </style>
</head>
<body>
    @await Html.PartialAsync("Sidebar")

    <main class="checkout-page">
        <div class="container checkout-layout">
            <section class="form-card">
                <h2>Thông tin người đặt</h2>
                <p style="font-size:.9rem;color:#6b7280;margin-bottom:1.5rem;">Vui lòng cung cấp thông tin để hoàn tất đặt phòng.</p>
                <form action="/checkout-homestay" method="POST" id="checkoutForm">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" style="margin-bottom: 1rem; color: #dc3545; background-color: #f8d7da; border-color: #f5c6cb; padding: .75rem 1.25rem; border: 1px solid transparent; border-radius: .25rem;">
                            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        </div>
                    }
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Họ và tên *</label>
                            <input type="text" name="BookerName" class="form-input" required placeholder="Nguyễn Văn A" value="@Model.BookerName">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Số điện thoại *</label>
                            <input type="tel" name="BookerPhone" class="form-input" required placeholder="09xxxxxxxx" value="@Model.BookerPhone">
                        </div>
                    </div>
                    <div class="form-group full-width">
                        <label class="form-label">Email *</label>
                        <input type="email" name="BookerEmail" class="form-input" required placeholder="nguyenvana@example.com" value="@Model.BookerEmail">
                    </div>
                    <div class="form-group full-width">
                        <label class="form-label">Yêu cầu đặc biệt (Nếu có)</label>
                        <textarea name="Notes" class="form-input" placeholder="Ví dụ: Tôi muốn nhận phòng sớm, vui lòng sắp xếp phòng ở tầng cao...">@Model.Notes</textarea>
                    </div>
                    <input type="hidden" name="RoomId" value="@Model.RoomId">
                    <input type="hidden" name="BusinessId" value="@Model.BusinessId">
                    <input type="hidden" name="CheckIn" value="@Model.CheckIn.ToString("yyyy-MM-dd")">
                    <input type="hidden" name="CheckOut" value="@Model.CheckOut.ToString("yyyy-MM-dd")">
                    <input type="hidden" name="NumGuests" value="@Model.NumGuests">
                    <input type="hidden" name="TotalAmount" value="@Model.TotalAmount">
                </form>
            </section>

            <aside class="summary-card">
                <h3>Chi tiết đặt phòng</h3>
                <h4>@Model.HomestayName</h4>
                <div class="summary-item-list">
                    <div class="summary-item">
                        <div>
                            <div class="summary-item-name">@Model.RoomName</div>
                            <div class="summary-item-meta">@Model.NumGuests người</div>
                        </div>
                        <div class="summary-item-price">@Model.PricePerNight.ToString("N0")₫/đêm</div>
                    </div>
                    <div class="summary-item">
                        <div>
                            <div class="summary-item-name">Nhận Phòng (Ngày đến)</div>
                            <div class="summary-item-meta">Từ 14:00</div>
                        </div>
                        <div class="summary-item-price">@Model.CheckIn.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="summary-item">
                        <div>
                            <div class="summary-item-name">Trả Phòng (Ngày đi)</div>
                            <div class="summary-item-meta">Từ 12:00</div>
                        </div>
                        <div class="summary-item-price">@Model.CheckOut.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
                <div class="summary-details">
                    <div class="detail-row"><span class="label">Số đêm</span><span>@Model.TotalNights đêm</span></div>
                    <div class="detail-row"><span class="label">Số khách</span><span>@Model.NumGuests người</span></div>
                </div>
                <div class="summary-total">
                    <div class="total-row">
                        <span class="label">Tổng cộng</span>
                        <span style="color:#d32f2f;">@Model.TotalAmount.ToString("N0")₫</span>
                    </div>
                </div>
                <button type="submit" form="checkoutForm" class="confirm-btn">
                    <i class="fas fa-check-circle"></i> Xác nhận và đặt phòng
                </button>
            </aside>
        </div>
    </main>

    @await Html.PartialAsync("Footer")
</body>
</html>
