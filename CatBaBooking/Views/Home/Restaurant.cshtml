@model CatBaBooking.ViewModels.Restaurant.RestaurantListViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nhà hàng tại Cát Bà - Cát Bà Booking</title>
    <link rel="stylesheet" href="~/css/HomePage/home-style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        .restaurants-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:20px;}
        .restaurant-card{background-color:#fff;border-radius:12px;box-shadow:0 4px 12px rgba(0,0,0,.08);overflow:hidden;transition:transform .3s ease,box-shadow .3s ease;display:flex;flex-direction:column;position:relative;}
        .restaurant-card:hover{transform:translateY(-5px);box-shadow:0 8px 20px rgba(0,0,0,.12);}
        .restaurant-card .card-image{position:relative;height:200px;}
        .restaurant-card .card-image img{width:100%;height:100%;object-fit:cover;}
        .restaurant-card .card-content{padding:16px;display:flex;flex-direction:column;flex-grow:1;}
        .restaurant-card .detail-btn{text-decoration:none;position:absolute;bottom:16px;right:16px;background-color:#28a745;color:#ffffff;padding:6px 12px;border-radius:6px;font-size:.9rem;}
        .restaurant-card .detail-btn:hover{background-color:#218838;color:#fff;}
        .pagination{display:flex;justify-content:center;align-items:center;gap:8px;margin:30px 0;flex-wrap:wrap;}
        .page-btn{min-width:40px;height:40px;padding:0 12px;border:1px solid #ddd;border-radius:6px;background:#fff;color:#6c757d;font-size:14px;text-decoration:none;display:flex;align-items:center;justify-content:center;transition:all .2s ease;cursor:pointer;}
        .page-btn.active{background-color:#28a745;color:white;border-color:#28a745;font-weight:600;}
        .page-btn:disabled{color:#aaa;background-color:#f8f9fa;cursor:not-allowed;}
        @@media(max-width:992px){.restaurants-grid{grid-template-columns:repeat(2,1fr);}}
        @@media(max-width:768px){.restaurants-grid{grid-template-columns:1fr;}}
        .apply-filter-btn{background-color:#007bff;color:white;border:none;padding:10px 16px;border-radius:6px;cursor:pointer;font-size:.95rem;margin-top:16px;width:100%;}
        .apply-filter-btn:hover{background-color:#0056b3;}
    </style>
</head>
<body>
    @await Html.PartialAsync("Sidebar")

    <section class="hero">
        <div class="hero-overlay"></div><div class="hero-bg"></div>
        <div class="container"><div class="hero-content">
            <div class="hero-text"><h1>Nhà hàng tại Cát Bà</h1><p>Khám phá ẩm thực đặc sắc và đặt bàn trực tuyến</p></div>
        </div></div>
    </section>

        <div class="container"><div class="main-content"><div class="content-layout">
            <div class="sidebar">
                <form id="filterForm" action="/restaurant-page" method="GET" class="filter-section">
                    <div class="filter-header"><i class="fas fa-sliders-h"></i><h3>Bộ lọc</h3></div>
                    
                    <div class="filter-group">
                        <h4>Khu vực</h4>
                        <div class="filter-options">
                            <label class="filter-option"><input type="radio" name="areaId" value="0" @(Model.AreaId == null || Model.AreaId == 0 ? "checked" : "")><span>Tất cả khu vực</span></label>
                            <label class="filter-option"><input type="radio" name="areaId" value="1" @(Model.AreaId == 1 ? "checked" : "")><span>TT.Cát Bà</span></label>
                            <label class="filter-option"><input type="radio" name="areaId" value="2" @(Model.AreaId == 2 ? "checked" : "")><span>Trung tâm Cát Bà</span></label>
                            <label class="filter-option"><input type="radio" name="areaId" value="3" @(Model.AreaId == 3 ? "checked" : "")><span>Vườn quốc gia Cát Bà</span></label>
                            <label class="filter-option"><input type="radio" name="areaId" value="4" @(Model.AreaId == 4 ? "checked" : "")><span>Làng Việt Hải</span></label>
                            <label class="filter-option"><input type="radio" name="areaId" value="5" @(Model.AreaId == 5 ? "checked" : "")><span>Bến Bèo</span></label>
                        </div>
                    </div>

                    <div class="filter-group">
                        <h4>Loại hình</h4>
                        <div class="filter-options">
                            <label class="filter-option"><input type="radio" name="restaurantType" value="" @(string.IsNullOrEmpty(Model.RestaurantType) ? "checked" : "")><span>Tất cả</span></label>
                            <label class="filter-option"><input type="radio" name="restaurantType" value="1" @(Model.RestaurantType == "1" ? "checked" : "")><span>Nhà hàng hải sản</span></label>
                            <label class="filter-option"><input type="radio" name="restaurantType" value="2" @(Model.RestaurantType == "2" ? "checked" : "")><span>Quán ăn địa phương</span></label>
                            <label class="filter-option"><input type="radio" name="restaurantType" value="3" @(Model.RestaurantType == "3" ? "checked" : "")><span>Nướng BBQ</span></label>
                            <label class="filter-option"><input type="radio" name="restaurantType" value="4" @(Model.RestaurantType == "4" ? "checked" : "")><span>Lẩu</span></label>
                        </div>
                    </div>

                    <div class="filter-group">
                        <h4>Đánh giá</h4>
                        <div class="filter-options">
                            <label class="filter-option"><input type="checkbox" name="minRating" value="5" @(Model.MinRating != null && Model.MinRating.Contains(5) ? "checked" : "")><div class="rating-option"><div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div><span>5 sao</span></div></label>
                            <label class="filter-option"><input type="checkbox" name="minRating" value="4" @(Model.MinRating != null && Model.MinRating.Contains(4) ? "checked" : "")><div class="rating-option"><div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i></div><span>4+ sao</span></div></label>
                            <label class="filter-option"><input type="checkbox" name="minRating" value="3" @(Model.MinRating != null && Model.MinRating.Contains(3) ? "checked" : "")><div class="rating-option"><div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i><i class="far fa-star"></i></div><span>3+ sao</span></div></label>
                        </div>
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <button type="submit" class="apply-filter-btn" style="flex: 1;">Áp dụng</button>
                        <a href="/restaurant-page" class="apply-filter-btn" style="flex: 1; background-color: #6c757d; text-align: center; text-decoration: none;">Xóa lọc</a>
                    </div>
                </form>
            </div>

            <div class="results-section">
                <div class="results-header">
                            <div class="results-info"><h2>Nhà hàng tại Cát Bà</h2><p>Tìm thấy <span>@Model.TotalCount</span> nhà hàng</p></div>
                    <div class="results-controls">
                        <div class="sort-control">
                            <label>Sắp xếp:</label>
                            <select name="sortOrder" form="filterForm" class="sort-select" onchange="this.form.submit()">
                                @if(Model.SortOrder == "Phù hợp nhất" || string.IsNullOrEmpty(Model.SortOrder)) { <option selected>Phù hợp nhất</option> } else { <option>Phù hợp nhất</option> }
                                @if(Model.SortOrder == "Đánh giá cao nhất") { <option selected>Đánh giá cao nhất</option> } else { <option>Đánh giá cao nhất</option> }
                            </select>
                        </div>
                    </div>
                </div>               

                        <div class="restaurants-grid">
                            @if (!Model.Items.Any())
                            {
                                <p style="grid-column:1/-1;text-align:center;color:#6c757d;">Không tìm thấy nhà hàng nào.</p>
                            }
                            @foreach (var restaurant in Model.Items)
                            {
                                <div class="restaurant-card">
                                    <div class="card-image">
                                        <img src="@(restaurant.ThumbnailUrl ?? "/images/default-restaurant.jpg")" alt="@restaurant.Name">
                                        <div class="badge cuisine"><i class="fas fa-utensils"></i> Restaurant</div>
                                    </div>
                                    <div class="card-content">
                                        <div class="rating-price">
                                            <div class="rating">
                                                <div class="stars">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= Math.Floor(restaurant.AverageRating))
                                                        {
                                                            <i class="fas fa-star"></i>
                                                        }
                                                        else if (i - restaurant.AverageRating < 1 && i - restaurant.AverageRating > 0)
                                                        {
                                                            <i class="fas fa-star-half-alt"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="far fa-star"></i>
                                                        }
                                                    }
                                                </div>
                                                <span class="reviews">(@restaurant.ReviewCount)</span>
                                            </div>
                                        </div>
                                        <h3>@restaurant.Name</h3>
                                        <div class="location"><i class="fas fa-map-marker-alt"></i> @(restaurant.AreaName ?? restaurant.Address)</div>
                                        <a class="detail-btn" href="/restaurant/detail/@restaurant.BusinessId">Chi tiết</a>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="pagination">
                    @{
                        var minRatingQs = Model.MinRating != null ? string.Join("", Model.MinRating.Select(r => $"&minRating={r}")) : "";
                        var qs = $"&areaId={Model.AreaId}&restaurantType={Model.RestaurantType}{minRatingQs}&sortOrder={Model.SortOrder}";
                    }
                    @if (Model.CurrentPage > 1)
                    {
                        <a href="?page=@(Model.CurrentPage - 1)@qs" class="page-btn"><i class="fas fa-chevron-left"></i></a>
                    }
                    else
                    {
                        <button class="page-btn" disabled><i class="fas fa-chevron-left"></i></button>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a href="?page=@i@qs" class="page-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
                    }

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a href="?page=@(Model.CurrentPage + 1)@qs" class="page-btn"><i class="fas fa-chevron-right"></i></a>
                    }
                    else
                    {
                        <button class="page-btn" disabled><i class="fas fa-chevron-right"></i></button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

    @await Html.PartialAsync("Footer")
</body>
</html>
