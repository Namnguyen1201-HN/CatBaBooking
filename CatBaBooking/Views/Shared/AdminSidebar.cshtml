@{
    string current = ViewData["ActivePage"]?.ToString() ?? "";

    string ActiveClass(string page) => current == page ? "active" : "";
}
<div class="sidebar">
    <div class="sidebar-header">Admin Panel</div>
    <div class="user-info">
        <div class="user-avatar">A</div>
        <span class="user-name">Admin</span>
    </div>
    <ul class="sidebar-menu">
        <li class="@ActiveClass("dashboard")"><a href="/dash-board">Dashboard</a></li>
        <li class="@ActiveClass("booking-history")"><a href="/booking-history">Lịch sử Booking</a></li>
        <li class="@ActiveClass("approve-application")"><a href="/approve-application">Duyệt Yêu Cầu</a></li>
        <li class="@ActiveClass("user-management")"><a href="/user-management">Quản Lý Người Dùng</a></li>
        <li class="@ActiveClass("permissions-manager")"><a href="/permissions-manager">Quản Lý Phân Quyền</a></li>
        <li class="@ActiveClass("feedback-management")"><a href="/feedback-management">Quản Lý Phản Hồi</a></li>
        <li class="@ActiveClass("business-stats")"><a href="/business-stats">Thống Kê Doanh Nghiệp</a></li>
    </ul>
    <div class="sidebar-footer">
        <form method="post" action="/logout">
            <button type="submit" class="logout-btn" onclick="return confirm('Bạn có chắc muốn đăng xuất?')">Đăng xuất</button>
        </form>
    </div>
</div>
