@using CatBaBooking.Models
@{
    Layout = null;
    List<Business> pendingBusinesses = ViewBag.PendingBusinesses ?? new List<Business>();
    string TypeLabel(string t) => t == "homestay" ? "Homestay" : "Nhà hàng";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Duyệt Yêu Cầu Đăng Ký</title>
    <link rel="stylesheet" href="~/css/Admin/admin-style.css">
    <style>
        .page-header { margin-bottom:20px; }
        .page-header h1 { margin:0; font-size:26px; color:#0f172a; }
        .page-header p { margin-top:6px; color:#64748b; }
        .card { background:#fff; border-radius:12px; border:1px solid #e2e8f0; box-shadow:0 8px 24px rgba(15,23,42,0.06); padding:24px; }
        .table { width:100%; border-collapse:collapse; }
        .table thead { background:#f8fafc; }
        .table th, .table td { padding:14px 20px; border-bottom:1px solid #e2e8f0; text-align:left; font-size:14px; color:#334155; }
        .table tbody tr:last-child td { border-bottom:none; }
        .btn { border:none; padding:10px 18px; border-radius:6px; font-size:14px; cursor:pointer; font-weight:600; text-decoration:none; display:inline-block; }
        .btn-back { background:#e2e8f0; color:#1f2937; }
        .empty-row { text-align:center; padding:32px 0; color:#94a3b8; font-size:14px; }
        .status-pending { background-color:#fffbe6; color:#d46b08; padding:4px 8px; border-radius:12px; font-size:0.9em; }
        .alert { padding:14px 18px; border-radius:8px; margin-bottom:20px; font-size:14px; }
        .alert-success { background:#dcfce7; color:#166534; border:1px solid #86efac; }
        .alert-error { background:#fee2e2; color:#b91c1c; border:1px solid #fca5a5; }
    </style>
</head>
<body>
    @await Html.PartialAsync("AdminSidebar")

    <div class="main-content">
        <div class="page-header">
            <h1>Duyệt yêu cầu đăng ký</h1>
            <p>Quản lý và xử lý các yêu cầu đăng ký chủ cơ sở mới.</p>
        </div>
        <main>
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-error">@TempData["ErrorMessage"]</div>
            }

            <div class="card">
                <table class="table">
                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>Tên cơ sở</th>
                            <th>Loại hình</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!pendingBusinesses.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-row">Không có yêu cầu nào đang chờ duyệt.</td>
                        </tr>
                    }
                    else
                    {
                        int stt = 1;
                        @foreach (var b in pendingBusinesses)
                        {
                            <tr>
                                <td>@(stt++)</td>
                                <td>@(b.Owner?.FullName ?? "")</td>
                                <td>@(b.Owner?.Email ?? "")</td>
                                <td>@b.Name</td>
                                <td>@TypeLabel(b.Type)</td>
                                <td><span class="status-pending">Đang chờ</span></td>
                                <td><a href="/approve-application/@b.BusinessId" class="btn btn-back">Xem chi tiết</a></td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</body>
</html>
