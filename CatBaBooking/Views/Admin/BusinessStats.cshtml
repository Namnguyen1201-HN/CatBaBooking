@using CatBaBooking.Models
@{
    Layout = null;

    List<(Business Business, int BookingCount, decimal Revenue, double AvgRating, int ReviewCount)> rows = ViewBag.Rows
        ?? new List<(Business, int, decimal, double, int)>();

    int totalCount = ViewBag.TotalCount;
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;

    string? type = ViewBag.Type;
    string? sort = ViewBag.Sort;

    string TypeLabel(string t) => t == "homestay" ? "Homestay" : "Nhà hàng";

    Func<int, string> pageUrl = p =>
    {
        var parts = new List<string> { $"page={p}" };
        if (!string.IsNullOrEmpty(type)) parts.Add($"type={Uri.EscapeDataString(type)}");
        if (!string.IsNullOrEmpty(sort)) parts.Add($"sort={Uri.EscapeDataString(sort)}");
        return "/business-stats?" + string.Join("&", parts);
    };
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Thống Kê Doanh Nghiệp</title>
    <link rel="stylesheet" href="~/css/Admin/admin-style.css">
    <style>
        .page-header { margin-bottom:20px; }
        .page-header h1 { margin:0; font-size:26px; color:#0f172a; }
        .page-header p { margin-top:6px; color:#64748b; }
        .filter-wrap { background:#fff; padding:20px; border-radius:8px; margin-bottom:20px; border:1px solid #e5e7eb; display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; align-items:end; }
        .filter-wrap > div { display:flex; flex-direction:column; }
        .filter-wrap label { display:block; margin-bottom:6px; font-size:13px; color:#475569; font-weight:500; }
        .filter-wrap select { width:100%; padding:8px 12px; border:1px solid #e5e7eb; border-radius:4px; font-size:14px; box-sizing:border-box; }
        .filter-wrap button { width:100%; padding:8px 16px; background:#3b82f6; color:#fff; border:none; border-radius:4px; font-size:14px; font-weight:500; cursor:pointer; }
        table { width:100%; border-collapse:collapse; background:#fff; border-radius:12px; overflow:hidden; border:1px solid #e2e8f0; }
        thead { background:#f8fafc; }
        th, td { padding:14px 16px; text-align:left; font-size:14px; border-bottom:1px solid #e2e8f0; color:#334155; }
        tbody tr:last-child td { border-bottom:none; }
        tbody tr:hover { background:#f8fafc; }
        .type-badge { display:inline-block; padding:4px 10px; background:#e0e7ff; color:#3730a3; border-radius:6px; font-size:12px; font-weight:600; }
        .rating-stars { color:#f59e0b; font-weight:600; }
        .rank-badge { display:inline-flex; align-items:center; justify-content:center; width:26px; height:26px; border-radius:50%; background:#f1f5f9; color:#475569; font-weight:700; font-size:13px; }
        .rank-badge.top { background:#fef3c7; color:#b45309; }
        .empty-row { text-align:center; padding:32px 0; color:#94a3b8; }
        .table-footer { padding:16px; background:#f8fafc; border-top:1px solid #e2e8f0; color:#64748b; font-size:14px; border-radius:0 0 12px 12px; }
        .pagination { display:flex; justify-content:center; align-items:center; gap:8px; margin-top:20px; }
        .pagination a, .pagination span { padding:8px 12px; border:1px solid #e2e8f0; border-radius:6px; text-decoration:none; color:#334155; font-size:14px; }
        .pagination a:hover { background:#f8fafc; }
        .pagination .current { background:#3b82f6; color:#fff; border-color:#3b82f6; }
        .pagination .disabled { color:#cbd5e1; pointer-events:none; }
        .pagination .ellipsis { border:none; }
    </style>
</head>
<body>
    @await Html.PartialAsync("AdminSidebar")

    <div class="main-content">
        <div class="page-header">
            <h1>Thống kê Doanh nghiệp</h1>
            <p>So sánh lượng booking, doanh thu và đánh giá giữa các Homestay/Nhà hàng trong hệ thống.</p>
        </div>
        <main>
            <form class="filter-wrap" method="get" action="/business-stats">
                <div>
                    <label>Loại hình</label>
                    <select name="type">
                        <option value="all" selected="@(string.IsNullOrEmpty(type))">Tất cả</option>
                        <option value="homestay" selected="@(type == "homestay")">Homestay</option>
                        <option value="restaurant" selected="@(type == "restaurant")">Nhà hàng</option>
                    </select>
                </div>
                <div>
                    <label>Sắp xếp theo</label>
                    <select name="sort">
                        <option value="booking_desc" selected="@(string.IsNullOrEmpty(sort) || sort == "booking_desc")">Booking: Nhiều → Ít</option>
                        <option value="booking_asc" selected="@(sort == "booking_asc")">Booking: Ít → Nhiều</option>
                        <option value="revenue_desc" selected="@(sort == "revenue_desc")">Doanh thu: Cao → Thấp</option>
                        <option value="revenue_asc" selected="@(sort == "revenue_asc")">Doanh thu: Thấp → Cao</option>
                        <option value="rating_desc" selected="@(sort == "rating_desc")">Đánh giá: Cao → Thấp</option>
                        <option value="rating_asc" selected="@(sort == "rating_asc")">Đánh giá: Thấp → Cao</option>
                    </select>
                </div>
                <div>
                    <button type="submit">Lọc</button>
                </div>
            </form>

            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tên cơ sở</th>
                        <th>Loại hình</th>
                        <th>Địa chỉ</th>
                        <th>Số Booking</th>
                        <th>Doanh thu</th>
                        <th>Đánh giá TB</th>
                    </tr>
                </thead>
                <tbody>
                @if (!rows.Any())
                {
                    <tr>
                        <td colspan="7" class="empty-row">Không có dữ liệu doanh nghiệp phù hợp.</td>
                    </tr>
                }
                else
                {
                    int rank = (currentPage - 1) * 10 + 1;
                    @foreach (var row in rows)
                    {
                        bool isTop = rank <= 3 && currentPage == 1;
                        <tr>
                            <td><span class="rank-badge @(isTop ? "top" : "")">@(rank++)</span></td>
                            <td><strong>@row.Business.Name</strong></td>
                            <td><span class="type-badge">@TypeLabel(row.Business.Type)</span></td>
                            <td>@row.Business.Address</td>
                            <td>@row.BookingCount.ToString("N0")</td>
                            <td>₫@row.Revenue.ToString("N0")</td>
                            <td>
                                @if (row.ReviewCount > 0)
                                {
                                    <span class="rating-stars">@row.AvgRating.ToString("0.0") ⭐</span>
                                    <span style="color:#94a3b8; font-size:12px;">(@row.ReviewCount lượt)</span>
                                }
                                else
                                {
                                    <span style="color:#94a3b8;">Chưa có đánh giá</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>

            @{
                ViewData["CurrentPage"] = currentPage;
                ViewData["TotalPages"] = totalPages;
                ViewData["PageUrlBuilder"] = pageUrl;
            }
            @await Html.PartialAsync("Pagination", ViewData)

            <div class="table-footer">
                Tổng số: <strong>@totalCount.ToString("N0")</strong> cơ sở
            </div>
        </main>
    </div>
</body>
</html>
