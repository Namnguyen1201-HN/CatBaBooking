@using CatBaBooking.Models
@{
    Layout = null;

    IEnumerable<User> users = ViewBag.Users ?? new List<User>();
    int totalCount = ViewBag.TotalCount;
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;

    string? search = ViewBag.Search;
    int? roleId = ViewBag.RoleId;
    string? status = ViewBag.Status;
    List<Role> roles = ViewBag.Roles ?? new List<Role>();

    string StatusClass(string s) => s switch
    {
        "active" => "status-active",
        "pending" => "status-pending",
        _ => "status-rejected"
    };

    string StatusLabel(string s) => s switch
    {
        "active" => "Hoạt động",
        "pending" => "Chờ duyệt",
        _ => "Không hoạt động"
    };

    Func<int, string> pageUrl = p =>
    {
        var parts = new List<string> { $"page={p}" };
        if (!string.IsNullOrEmpty(search)) parts.Add($"search={Uri.EscapeDataString(search)}");
        if (roleId.HasValue) parts.Add($"roleId={roleId}");
        if (!string.IsNullOrEmpty(status)) parts.Add($"status={Uri.EscapeDataString(status)}");
        return "/user-management?" + string.Join("&", parts);
    };
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Quản Lý Người Dùng</title>
    <link rel="stylesheet" href="~/css/Admin/admin-style.css">
    <style>
            .btn-back {
                background-color: #d9d9d9;
                color: #333;
                padding: 8px 16px;
                border: none;
                border-radius: 4px;
                cursor: pointer;
                text-decoration: none;
                display: inline-block;
            }

                .btn-back:hover {
                    background-color: #bfbfbf;
                }

            .search-container {
                display: flex;
                gap: 12px;
                margin-bottom: 20px;
                flex-wrap: wrap;
            }

                .search-container input, .search-container select {
                    padding: 10px 12px;
                    border: 1px solid #e2e8f0;
                    border-radius: 6px;
                    font-size: 14px;
                }

                .search-container button {
                    padding: 10px 20px;
                    background: #3b82f6;
                    color: #fff;
                    border: none;
                    border-radius: 6px;
                    cursor: pointer;
                    font-weight: 500;
                }

                    .search-container button:hover {
                        background: #2563eb;
                    }

            table {
                width: 100%;
                border-collapse: collapse;
                background: #fff;
                border-radius: 12px;
                overflow: hidden;
                border: 1px solid #e2e8f0;
            }

            thead {
                background: #f8fafc;
            }

            th, td {
                padding: 14px 16px;
                text-align: left;
                font-size: 14px;
                border-bottom: 1px solid #e2e8f0;
            }

            tbody tr:last-child td {
                border-bottom: none;
            }

            .status-active {
                background: #dcfce7;
                color: #166534;
                padding: 4px 10px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 600;
            }

            .status-pending {
                background: #fef3c7;
                color: #b45309;
                padding: 4px 10px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 600;
            }

            .status-rejected {
                background: #fee2e2;
                color: #b91c1c;
                padding: 4px 10px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 600;
            }

            .action-buttons {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .btn-view {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                background: #3b82f6;
                color: #ffffff !important;
                padding: 7px 14px;
                border-radius: 6px;
                font-weight: 600;
                font-size: 13px;
                text-decoration: none !important;
                border: none;
                white-space: nowrap;
                transition: background .15s;
            }

                .btn-view svg {
                    width: 14px;
                    height: 14px;
                    flex-shrink: 0;
                }

                .btn-view:hover {
                    background: #2563eb;
                }

            .toggle-switch {
                position: relative;
                width: 40px;
                height: 22px;
            }

                .toggle-switch input {
                    opacity: 0;
                    width: 0;
                    height: 0;
                }

                .toggle-switch label {
                    position: absolute;
                    inset: 0;
                    background: #cbd5e1;
                    border-radius: 999px;
                    cursor: pointer;
                    transition: .2s;
                }

                    .toggle-switch label::before {
                        content: "";
                        position: absolute;
                        width: 16px;
                        height: 16px;
                        left: 3px;
                        top: 3px;
                        background: #fff;
                        border-radius: 50%;
                        transition: .2s;
                    }

                .toggle-switch input:checked + label {
                    background: #22c55e;
                }

                    .toggle-switch input:checked + label::before {
                        transform: translateX(18px);
                    }

            .pagination {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 8px;
                margin-top: 20px;
            }

                .pagination a, .pagination span {
                    padding: 8px 12px;
                    border: 1px solid #e2e8f0;
                    border-radius: 6px;
                    text-decoration: none;
                    color: #334155;
                    font-size: 14px;
                }

                    .pagination a:hover {
                        background: #f8fafc;
                    }

                .pagination .current {
                    background: #3b82f6;
                    color: #fff;
                    border-color: #3b82f6;
                }

                .pagination .disabled {
                    color: #cbd5e1;
                    pointer-events: none;
                }

                .pagination .ellipsis {
                    border: none;
                }

            .alert {
                padding: 14px 18px;
                border-radius: 8px;
                margin-bottom: 20px;
                font-size: 14px;
            }

            .alert-success {
                background: #dcfce7;
                color: #166534;
                border: 1px solid #86efac;
            }

            .alert-error {
                background: #fee2e2;
                color: #b91c1c;
                border: 1px solid #fca5a5;
            }

            .table-footer {
                padding: 14px 16px;
                background: #f8fafc;
                border-top: 1px solid #e2e8f0;
                color: #64748b;
                font-size: 14px;
                border-radius: 0 0 12px 12px;
            }
    </style>
</head>
<body>
    @await Html.PartialAsync("AdminSidebar")

    <div class="main-content">
        <main>
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-error">@TempData["ErrorMessage"]</div>
            }

            <form class="search-container" method="get" action="/user-management">
                <input type="text" name="search" value="@search" placeholder="Tìm kiếm theo tên hoặc email">
                <select name="roleId">
                    <option value="">Tất cả quyền</option>
                    @foreach (var r in roles)
                    {
                        <option value="@r.RoleId" selected="@(roleId == r.RoleId)">@r.RoleName</option>
                    }
                </select>
                <select name="status">
                    <option value="all" selected="@(string.IsNullOrEmpty(status))">Tất cả trạng thái</option>
                    <option value="active" selected="@(status == "active")">Hoạt động</option>
                    <option value="pending" selected="@(status == "pending")">Chờ duyệt</option>
                    <option value="rejected" selected="@(status == "rejected")">Không hoạt động</option>
                </select>
                <button type="submit">Tìm kiếm</button>
            </form>

            <table>
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Họ Tên</th>
                        <th>Email</th>
                        <th>Quyền</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!users.Any())
                    {
                        <tr>
                            <td colspan="6" style="text-align:center; color:#94a3b8;">Không tìm thấy người dùng nào.</td>
                        </tr>
                    }
                    else
                    {
                        int stt = (currentPage - 1) * 10 + 1;
                        @foreach (var u in users)
                        {
                            string toggleId = $"toggle{u.UserId}";
                            <tr>
                                <td>@(stt++)</td>
                                <td>@u.FullName</td>
                                <td>@u.Email</td>
                                <td>@(u.Role?.RoleName ?? "")</td>
                                <td><span class="@StatusClass(u.Status)">@StatusLabel(u.Status)</span></td>
                                <td>
                                    <div class="action-buttons">
                                        <a class="btn-view" href="/user-management/@u.UserId">
                                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2" />
                                            </svg>
                                            Chi tiết
                                        </a>
                                        <form method="post" action="/user-management/@u.UserId/toggle-status" id="form-@toggleId">
                                            <input type="hidden" name="newStatus" id="input-@toggleId" value="@(u.Status == "active" ? "rejected" : "active")">
                                            <div class="toggle-switch">
                                                <input type="checkbox" id="@toggleId" @(u.Status == "active" ? "checked" : "")
                                                       onchange="toggleConfirm(this, '@toggleId')">
                                                <label for="@toggleId"></label>
                                            </div>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @{
                ViewData["CurrentPage"] = currentPage;
                ViewData["TotalPages"] = totalPages;
                ViewData["PageUrlBuilder"] = pageUrl;
            }
            @await Html.PartialAsync("Pagination", ViewData)

            <div class="table-footer">
                Tổng số: <strong>@totalCount.ToString("N0")</strong> người dùng
            </div>
        </main>
    </div>

    <script>
                function toggleConfirm(checkbox, toggleId) {
                const newStatus = checkbox.checked ? 'active' : 'rejected';
                if (!confirm('Xác nhận thay đổi trạng thái sang ' + (newStatus === 'active' ? 'Hoạt động' : 'Không hoạt động') + '?')) {
                    checkbox.checked = !checkbox.checked;
                    return;
                    }
                document.getElementById('input-' + toggleId).value = newStatus;
                document.getElementById('form-' + toggleId).submit();
            }
    </script>
</body>
</html>
