@using CatBaBooking.Models
@{
    Layout = null;

    List<Booking> bookings = ViewBag.Bookings ?? new List<Booking>();
    int totalCount = ViewBag.TotalCount;
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;

    string? status = ViewBag.Status;
    string? type = ViewBag.Type;
    string? search = ViewBag.Search;

    string BadgeClass(string s) => s switch
    {
        "confirmed" or "completed" => "confirmed",
        "pending" => "pending",
        _ => "cancelled"
    };

    string BadgeLabel(string s) => s switch
    {
        "confirmed" => "Đã xác nhận",
        "completed" => "Hoàn tất",
        "pending" => "Đang chờ",
        "cancelled_by_user" => "Khách hủy",
        "cancelled_by_owner" => "Chủ hủy",
        "no_show" => "Không đến",
        _ => s
    };

    string TypeLabel(string? t) => t == "homestay" ? "Homestay" : "Nhà hàng";

    (string Text, string Color) PaymentLabel(string? p) => p switch
    {
        "fully_paid" => ("Đã thanh toán", "#166534"),
        "partially_paid" => ("Thanh toán một phần", "#b45309"),
        "refunded" => ("Đã hoàn tiền", "#64748b"),
        _ => ("Chưa thanh toán", "#b91c1c")
    };

    string QueryString(int targetPage)
    {
        var parts = new List<string> { $"page={targetPage}" };
        if (!string.IsNullOrEmpty(status)) parts.Add($"status={Uri.EscapeDataString(status)}");
        if (!string.IsNullOrEmpty(type)) parts.Add($"type={Uri.EscapeDataString(type)}");
        if (!string.IsNullOrEmpty(search)) parts.Add($"search={Uri.EscapeDataString(search)}");
        return "/booking-history?" + string.Join("&", parts);
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Lịch sử Booking</title>
    <link rel="stylesheet" href="~/css/Admin/admin-style.css">
    <style>
        .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; }
        .page-header h1 { font-size:28px; color:#0f172a; margin:0; }
        .filters-section { background:#fff; border-radius:12px; padding:20px; margin-bottom:24px; border:1px solid #e2e8f0; }
        .filters-form { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; align-items:end; }
        .filter-group { display:flex; flex-direction:column; }
        .filter-group label { font-size:13px; color:#64748b; margin-bottom:6px; font-weight:500; }
        .filter-group select, .filter-group input { padding:10px 12px; border:1px solid #e2e8f0; border-radius:6px; font-size:14px; }
        .filter-group input:focus, .filter-group select:focus { outline:none; border-color:#3b82f6; }
        .btn-filter { padding:10px 20px; background:#3b82f6; color:#fff; border:none; border-radius:6px; cursor:pointer; font-size:14px; font-weight:500; }
        .btn-filter:hover { background:#2563eb; }
        .bookings-table { width:100%; border-collapse:collapse; background:#fff; border-radius:12px; overflow:hidden; border:1px solid #e2e8f0; }
        .bookings-table thead { background:#f8fafc; }
        .bookings-table th { padding:14px 16px; text-align:left; font-size:12px; color:#475569; text-transform:uppercase; font-weight:600; border-bottom:2px solid #e2e8f0; }
        .bookings-table td { padding:14px 16px; font-size:14px; color:#334155; border-bottom:1px solid #e2e8f0; }
        .bookings-table tbody tr:hover { background:#f8fafc; }
        .bookings-table tbody tr:last-child td { border-bottom:none; }
        .status-badge { display:inline-flex; align-items:center; gap:6px; padding:4px 10px; border-radius:999px; font-size:12px; font-weight:600; text-transform:uppercase; }
        .status-badge.pending { background:#fef3c7; color:#b45309; }
        .status-badge.confirmed { background:#dcfce7; color:#166534; }
        .status-badge.cancelled { background:#fee2e2; color:#b91c1c; }
        .pagination { display:flex; justify-content:center; align-items:center; gap:8px; margin-top:24px; }
        .pagination a, .pagination span { padding:8px 12px; border:1px solid #e2e8f0; border-radius:6px; text-decoration:none; color:#334155; font-size:14px; }
        .pagination a:hover { background:#f8fafc; }
        .pagination .current { background:#3b82f6; color:#fff; border-color:#3b82f6; }
        .pagination .disabled { color:#cbd5e1; pointer-events:none; }
        .info-badge { display:inline-block; padding:4px 8px; background:#e0e7ff; color:#3730a3; border-radius:4px; font-size:12px; font-weight:500; }
        .table-footer { padding:16px; background:#f8fafc; border-top:1px solid #e2e8f0; color:#64748b; font-size:14px; }
    </style>
</head>
<body>
    @await Html.PartialAsync("AdminSidebar")

    <div class="main-content">
        <div class="page-header">
            <div>
                <h1>Lịch sử Booking</h1>
                <p style="color:#64748b; margin-top:6px; font-size:14px;">Quản lý tất cả đơn đặt phòng và đặt bàn trong hệ thống</p>
            </div>
        </div>

        <form class="filters-section" method="get" action="/booking-history">
            <div class="filters-form">
                <div class="filter-group">
                    <label>Trạng thái</label>
                    <select name="status">
                        <option value="all" selected="@(string.IsNullOrEmpty(status))">Tất cả</option>
                        <option value="pending" selected="@(status == "pending")">Đang chờ</option>
                        <option value="confirmed" selected="@(status == "confirmed")">Đã xác nhận</option>
                        <option value="completed" selected="@(status == "completed")">Hoàn tất</option>
                        <option value="cancelled_by_user" selected="@(status == "cancelled_by_user")">Đã hủy (Khách)</option>
                        <option value="cancelled_by_owner" selected="@(status == "cancelled_by_owner")">Đã hủy (Chủ CS)</option>
                        <option value="no_show" selected="@(status == "no_show")">Không đến</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>Loại hình</label>
                    <select name="type">
                        <option value="all" selected="@(string.IsNullOrEmpty(type))">Tất cả</option>
                        <option value="homestay" selected="@(type == "homestay")">Homestay</option>
                        <option value="restaurant" selected="@(type == "restaurant")">Nhà hàng</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>Tìm kiếm</label>
                    <input type="text" name="search" value="@search" placeholder="Mã booking, tên, email, SĐT...">
                </div>
                <div class="filter-group">
                    <button type="submit" class="btn-filter">Lọc</button>
                </div>
            </div>
        </form>

        <div style="background:#fff; border-radius:12px; border:1px solid #e2e8f0; overflow:hidden;">
            <table class="bookings-table">
                <thead>
                    <tr>
                        <th>Mã Booking</th>
                        <th>Khách hàng</th>
                        <th>Cơ sở</th>
                        <th>Loại hình</th>
                        <th>Số khách</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                        <th>Ngày đặt</th>
                    </tr>
                </thead>
                <tbody>
                @if (!bookings.Any())
                {
                    <tr>
                        <td colspan="9" style="text-align:center; color:#94a3b8;">Không tìm thấy booking nào phù hợp.</td>
                    </tr>
                }
                else
                {
                    @foreach (var b in bookings)
                    {
                        var payment = PaymentLabel(b.PaymentStatus);
                        <tr>
                            <td><strong>#@b.BookingCode</strong></td>
                            <td>@b.BookerName<br><small style="color:#94a3b8;">@b.BookerEmail</small></td>
                            <td>@(b.Business?.Name ?? "")<br><small style="color:#94a3b8;">@(b.Business?.Address ?? "")</small></td>
                            <td><span class="info-badge">@TypeLabel(b.Business?.Type)</span></td>
                            <td>@b.NumGuests người</td>
                            <td><strong>₫@b.TotalPrice.ToString("N0")</strong></td>
                            <td><span style="color:@payment.Color; font-weight:500;">@payment.Text</span></td>
                            <td><span class="status-badge @BadgeClass(b.Status)">@BadgeLabel(b.Status)</span></td>
                            <td>@(b.CreatedAt?.ToString("dd/MM/yyyy") ?? "")</td>
                        </tr>
                    }
                }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    @if (currentPage > 1)
                    {
                        <a href="@QueryString(currentPage - 1)">« Trước</a>
                    }
                    else
                    {
                        <span class="disabled">« Trước</span>
                    }

                    @for (int p = 1; p <= totalPages; p++)
                    {
                        if (p == currentPage)
                        {
                            <span class="current">@p</span>
                        }
                        else
                        {
                            <a href="@QueryString(p)">@p</a>
                        }
                    }

                    @if (currentPage < totalPages)
                    {
                        <a href="@QueryString(currentPage + 1)">Sau »</a>
                    }
                    else
                    {
                        <span class="disabled">Sau »</span>
                    }
                </div>
            }

            <div class="table-footer">
                Tổng số: <strong>@totalCount.ToString("N0")</strong> booking
            </div>
        </div>
    </div>
</body>
</html>
